# ============================================================
# AgentsOffice 环境变量配置
# 复制此文件为 .env 并填入你的真实值
# .env 已加入 .gitignore，不会被提交到 git
# ============================================================

# ---------- 数据库 ----------
DATABASE_URL_SYNC=postgresql://ecom_dev:ecom_dev_pass@localhost:5432/ecom_ai_lab

# ---------- LLM API Keys（填你有的，没有的留空） ----------
# Google Gemini
GEMINI_API_KEY=

# Anthropic Claude（可选）
ANTHROPIC_API_KEY=

# OpenAI ChatGPT（可选）
OPENAI_API_KEY=

# DeepSeek（可选）
DEEPSEEK_API_KEY=

# 阿里云百炼 DashScope（可选）
DASHSCOPE_API_KEY=

# ---------- 默认模型配置 ----------
# 每个 Agent 可在配置面板单独设置模型，这里是全局默认
DEFAULT_LLM_MODEL=gemini/gemini-2.5-flash

# ---------- OpenClaw 采集适配器 ----------
OPENCLAW_MODE=mock
OPENCLAW_REMOTE_BASE_URL=http://127.0.0.1:9001
OPENCLAW_TIMEOUT_SECONDS=15
